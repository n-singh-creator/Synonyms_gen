# =============================================================================
# Environment Variables for Synonym Generation & Search Quality Analysis
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then load into your shell:
#   source .env
#
# No dotenv library is used -- variables must be exported in the shell.
# =============================================================================

# LiteLLM API key for Mercari's LiteLLM proxy (https://litellm.mercari.in/v1)
# Used by:
#   - Go synonym generator   (Synonym_genrator/vertex.go)
#   - Python query explainer  (LLmHelper/query_explainer.py)
# Obtain from: Mercari LiteLLM admin
LITELLM_API_KEY=your-litellm-api-key-here
